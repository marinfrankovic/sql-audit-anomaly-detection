// AI-4) Single anomaly by user (evidence for explain_anomaly) ----------------
// Provide UserName as a parameter when calling from run-ai-analysis.ps1.
// SQLSecurityAuditEvents
// | where TimeGenerated > ago(1d) and ServerPrincipalName == "<UserName>"
// | project EventTime=TimeGenerated, UserName=ServerPrincipalName, DatabaseName, ObjectName, ClientIp, Statement=substring(Statement,0,400)
// | order by EventTime desc
// | take 20

